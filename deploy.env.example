# Image names pushed to your registry.
SPOTAI_BACKEND_IMAGE=registry.example.com/spotai/spotai-backend:1.0.0
SPOTAI_WEB_IMAGE=registry.example.com/spotai/spotai-web:1.0.0

# Public ports on the cloud server.
WEB_PUBLIC_PORT=80
BACKEND_PUBLIC_PORT=8080
MYSQL_PUBLIC_PORT=3306
REDIS_PUBLIC_PORT=6379
MINIO_PUBLIC_PORT=19000
MINIO_CONSOLE_PUBLIC_PORT=19001

# Infrastructure secrets. Use strong passwords in production.
MYSQL_PASSWORD=change_me_mysql
REDIS_PASSWORD=change_me_redis
MINIO_SECRET_KEY=change_me_minio_8_chars_min

# MinIO public address used in uploaded image URLs.
# Replace SERVER_IP_OR_DOMAIN with your cloud server public IP or domain.
MINIO_EXTERNAL_ENDPOINT=http://SERVER_IP_OR_DOMAIN:19000

# Mail login code provider.
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_mail@qq.com
MAIL_PASSWORD=your_smtp_authorization_code

# AI providers.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
SPOTAI_AI_ENABLED=false
REVIEW_AI_ADMIN_KEY=change_me_review_admin_key

# Keep false unless RocketMQ is also deployed.
SPOTAI_MQ_ENABLED=false
SPOTAI_VOUCHER_MQ_ENABLED=false

# JVM memory, tune by server size.
JAVA_OPTS=-Xms256m -Xmx768m
